# ═══════════════════════════════════════════════════════════
#  CUMPLEFY — Environment Variables
#  Copy this file to .env.local and fill in the values.
#  Never commit .env.local to git.
# ═══════════════════════════════════════════════════════════

# ── DATABASE (Supabase Transaction Mode Pooler) ───────────
# Dashboard → Settings → Database → Connection string → Transaction mode (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── SUPABASE ──────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NEVER expose client-side

# ── CLERK AUTH ────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=whsec_...     # Webhooks → Signing secret

# ── STRIPE ────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Product price for pay-per-event (€19 one-time)
STRIPE_EVENT_PRICE_ID=price_...

# ── CLOUDFLARE R2 ─────────────────────────────────────────
# Cloudflare Dashboard → R2 → Manage API tokens
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cumplefy-media
# Public custom domain bound to the bucket
R2_PUBLIC_URL=https://media.cumplefy.com

# ── KIE.AI (video / image pipeline) ─────────────────────
# https://kie.ai → API Keys (dashboard → API)
KIE_API_KEY=
KIE_API_BASE_URL=https://api.kie.ai

# Callback URL — Kie.ai llamará aquí al completar generaciones async
# Dev: tunnel ngrok → https://<id>.ngrok.io/api/integrations/kie/callback
# Prod: https://cumplefy.com/api/integrations/kie/callback
KIE_CALLBACK_URL=

# Secreto compartido para validar callbacks entrantes de Kie.ai
# Generar con: openssl rand -hex 32
KIE_WEBHOOK_SECRET=

# ── UPSTASH REDIS (caching) ──────────────────────────────
# https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://[id].upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── UPSTASH QSTASH (async job queue) ────────────────────
# https://console.upstash.com → QStash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── RESEND EMAIL ─────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hola@cumplefy.com

# ── ELEVENLABS VOICE SYNTHESIS ───────────────────────────
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=
# Default voice for Spanish — find at /v1/voices
ELEVENLABS_DEFAULT_VOICE_ID=

# ── N8N ORCHESTRATION (Railway hosted) ───────────────────
# Your n8n instance URL and API key
N8N_WEBHOOK_URL=https://n8n.railway.app/webhook
N8N_API_KEY=

# ── APP ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://cumplefy.com
# Anthropic API for Genio chatbot
ANTHROPIC_API_KEY=sk-ant-...

# ── GIFT SEARCH (Serper.dev Google Shopping) ─────────────
# https://serper.dev → API Keys (~$0.001/query)
SERPER_API_KEY=

# ── AFFILIATE TAGS ────────────────────────────────────────
# Amazon Associates — https://affiliate-program.amazon.es
# Format: "cumplefy-21"  (last 2 digits = ES market)
AFFILIATE_TAG_AMAZON=

# Awin Network — https://www.awin.com (covers ECI, Fnac, Zara, IKEA, etc.)
# Your Awin Publisher ID (found in Awin dashboard → Account → Publisher ID)
AFFILIATE_AWIN_PUBLISHER_ID=

# Awin Merchant IDs — find at https://www.awin.com/gb/advertiser-directory
# El Corte Inglés
AFFILIATE_AWIN_MID_ECI=
# Fnac España
AFFILIATE_AWIN_MID_FNAC=
# PcComponentes
AFFILIATE_AWIN_MID_PCCOMP=
# Zara / Inditex
AFFILIATE_AWIN_MID_ZARA=
# MediaMarkt España
AFFILIATE_AWIN_MID_MEDIAMARKT=
# IKEA España
AFFILIATE_AWIN_MID_IKEA=

# AliExpress — https://portals.aliexpress.com (own affiliate program)
AFFILIATE_TAG_ALIEXPRESS=
